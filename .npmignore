# place per-project settings here

/tools
OLD.*
README_old.md
emergency.eslint.config.mjs

# =========================================
# common part
# =========================================

*.sublime-project
*.sublime-workspace

# nx files
project.json

# PRIVATE files
.env
.npmrc
.node_repl_history

# dependencies
.npm
.npm-cache/
.pnpm-store/
node_modules/
**/node_modules/
bower_components/

# compiled output
tmp/
build/

# Coverage directory used by tools like istanbul
coverage/
lib-cov/

npm-debug.log*
logs/
log/
*.log
testem.log

# ----------
# test files
# ----------

test/
tests/
**/*.spec.js
**/*.test.js
**/*.spec.?js
**/*.test.?js

