{
  "name": "eslint-config-volebo",
  "version": "4.0.0-beta.3",
  "description": "ESLint rules for volebo.net",
  "license": "SEE LICENSE IN LICENSE",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": "./src/index.mjs",
  "imports": {
    "#src/*": "./src/*",
    "#tests/*": "./tests/*"
  },
  "scripts": {
    "test": "npx mocha",
    "lint": "npx eslint ./src/",
    "coverage": "node tools/nyc-to-c8.mjs .c8rc.json && npx c8 mocha"
  },
  "author": {
    "name": "Volebo Dev Team",
    "url": "https://dev.volebo.net"
  },
  "contributors": [
    {
      "name": "Maksim Koryukov",
      "email": "maxkoryukov@volebo.net",
      "url": "https://www.npmjs.com/~maxkoryukov"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/volebo/eslint-config-volebo.git"
  },
  "bugs": {
    "url": "https://gitlab.com/volebo/eslint-config-volebo/issues"
  },
  "homepage": "https://gitlab.com/volebo/eslint-config-volebo",
  "keywords": [
    "eslintconfig",
    "eslint",
    "volebo.net",
    "volebo"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "c8": "^10.1.2",
    "chai": "^5.1.1",
    "mocha": "^10.7.3"
  },
  "peerDependencies": {
    "eslint": ">= 9.0.0"
  },
  "dependencies": {
    "eslint-plugin-chai-friendly": "^1.0.1",
    "eslint-plugin-mocha": "^10.5.0",
    "eslint-plugin-unicorn": "^56.0.0",
    "globals": "^15.11.0",
    "neostandard": "^0.11.6"
  }
}
